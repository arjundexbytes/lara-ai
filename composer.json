{
  "name": "enterprise/lara-ai",
  "type": "project",
  "description": "Laravel 12 enterprise AI orchestration skeleton",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^12.0",
    "laravel/octane": "^2.8",
    "laravel/scout": "^10.0",
    "inertiajs/inertia-laravel": "^2.0",
    "doctrine/orm": "^3.2",
    "doctrine/dbal": "^4.0",
    "predis/predis": "^2.2",
    "jms/serializer": "^3.30",
    "openai-php/laravel": "^0.13"
  },
  "require-dev": {
    "laravel/breeze": "^2.3",
    "nunomaduro/larastan": "^3.0",
    "phpunit/phpunit": "^11.0",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php artisan migrate --force"
    ],
    "setup": [
      "composer install",
      "php artisan breeze:install react",
      "npm install",
      "npm run build"
    ],
    "analyse": [
      "vendor/bin/phpstan analyse --memory-limit=1G"
    ]
  }
}
