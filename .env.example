APP_NAME=LaraAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lara_ai
DB_USERNAME=root
DB_PASSWORD=
# Optional PostgreSQL
# DB_CONNECTION=pgsql
# DB_PORT=5432

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SCOUT_DRIVER=database
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

AI_PROVIDER=openai
AI_ENDPOINT=https://api.openai.com/v1
AI_EMBEDDING_MODEL=text-embedding-3-large
AI_COMPLETION_MODEL=gpt-4.1
MCP_ENABLED=true

OCTANE_SERVER=swoole
OCTANE_HTTPS=false
BOOST_ENABLED=false
